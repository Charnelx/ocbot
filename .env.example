# =============================================================================
# SHARED (no prefix)
# =============================================================================

# Database
# PostgreSQL connection URL (postgresql+asyncpg://user:pass@host:port/db)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ocbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ocbot

# =============================================================================
# SCRAPER SERVICE (prefix: SCRAPER_)
# =============================================================================

# Logging
SCRAPER_LOG_LEVEL=INFO

# Forum URL
SCRAPER_FORUM_BASE_URL=https://forum.overclockers.ua/viewforum.php?f=26
SCRAPER_FORUM_BASE_DOMAIN=https://forum.overclockers.ua

# Embedding model
SCRAPER_EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Scraping parameters
SCRAPER_DEFAULT_BULK_SIZE=10
SCRAPER_DEFAULT_BULK_DELAY_MS=2000
SCRAPER_DEFAULT_PAGE_COUNT=1
SCRAPER_DEFAULT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
SCRAPER_TOPICS_PER_PAGE=40

# Cleanup Job (uses SEARCH_ prefix for backward compatibility)
SEARCH_STALE_TOPIC_DAYS=10

# Webhook for n8n orchestration (called when task completes)
SCRAPER_WEBHOOK_URL=http://n8n:5678/webhook/scraper-done

# =============================================================================
# ENRICHMENT SERVICE (prefix: ENRICHMENT_)
# =============================================================================

# Logging
ENRICHMENT_LOG_LEVEL=INFO

# OpenRouter API
ENRICHMENT_OPENROUTER_API_KEY=

# LLM settings
ENRICHMENT_LLM_MODEL=arcee-ai/trinity-large-preview:free
ENRICHMENT_LLM_MAX_TOKENS=8096
ENRICHMENT_LLM_MAX_ATTEMPTS=3

# Enrichment limits
ENRICHMENT_DEFAULT_LIMIT=10
ENRICHMENT_MAX_LIMIT=100
ENRICHMENT_CONCURRENCY=5
ENRICHMENT_MAX_TOPIC_ATTEMPTS=3
ENRICHMENT_MAX_CONTENT_CHARS=8000

# Embedding model (can share with scraper)
ENRICHMENT_EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Webhook for n8n orchestration
ENRICHMENT_WEBHOOK_URL=http://n8n:5678/webhook/enrich-done

# =============================================================================
# SEARCH SERVICE (prefix: SEARCH_)
# =============================================================================

# Logging
SEARCH_LOG_LEVEL=INFO

# Database (uses shared DATABASE_URL, not prefixed)
SEARCH_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ocbot

# OpenRouter API (can share with enrichment)
SEARCH_OPENROUTER_API_KEY=

# LLM settings
SEARCH_LLM_MODEL=arcee-ai/trinity-large-preview:free
SEARCH_LLM_MAX_TOKENS=1024
SEARCH_SMART_TIMEOUT_SECONDS=30.0

# Search thresholds
SEARCH_CONFIDENCE_THRESHOLD=0.7
SEARCH_SCORE_WEIGHT_LABELS=0.85
SEARCH_SCORE_WEIGHT_COSINE=0.15
SEARCH_MIN_SIMILARITY=0.6

# Search limits
SEARCH_DEFAULT_LIMIT=20
SEARCH_MAX_LIMIT=100
SEARCH_MAX_QUERY_CHARS=500

# Wikipedia tool
SEARCH_WIKIPEDIA_TIMEOUT_SECONDS=5.0
SEARCH_WIKIPEDIA_MAX_CHARS=1500

# URL template
SEARCH_TOPIC_URL_TEMPLATE=https://overclockers.ua/forum/{external_id}

# Ranking algorithm: "recall" (default) or "precision"
SEARCH_RANKING_ALGORITHM=precision
SEARCH_SCORE_AUTO_TUNE_STEP=0.05

# Embedding model (can share with scraper/enrichment)
SEARCH_EMBEDDING_MODEL=intfloat/multilingual-e5-large

# =============================================================================
# THIRD-PARTY LIBRARIES
# =============================================================================

# Transformers library logging (debug, info, warning, error, critical)
TRANSFORMERS_VERBOSITY=error

# =============================================================================
# N8N ORCHESTRATOR
# =============================================================================

N8N_USER=admin
N8N_PASSWORD=admin
